%%%============================================================
\protected\def\bm#1{\symbf{#1}}
\protected\def\boldsymbol#1{\symbf{#1}}

% Restore classical Computer Modern calligraphic \mathcal
\DeclareMathAlphabet{\mathcal}{OMS}{cmsy}{m}{n}

% Math color wrapper helper
\def\class#1#2{{\color{#1}#2}}

%%%============================================================
%%%  Path constants
%%%============================================================
% These can be modified, but the UCL fonts and logo images must be
% available and the sty file must know where to look for them!
\providecommand{\UCLfontpath}{css/fonts/}
\providecommand{\UCLimgpath}{images/}

%%%============================================================
%%%  Fonts
%%%============================================================
\setmainfont{UCLSans}[
  Path             = \UCLfontpath,
  Extension        = .ttf,
  UprightFont      = *-Regular,
  BoldFont         = *-Bold,
  FontFace         = {sb}{n}{*-SemiBold},
  AutoFakeSlant    = 0.18,
]
\setsansfont{UCLSans}[
  Path             = \UCLfontpath,
  Extension        = .ttf,
  UprightFont      = *-Regular,
  BoldFont         = *-Bold,
  FontFace         = {sb}{n}{*-SemiBold},
  AutoFakeSlant    = 0.18,
]

\IfFontExistsTF{Ubuntu Mono}{%
