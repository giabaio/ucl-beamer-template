%%%============================================================
%%%  Beamer colour scheme
%%%============================================================
\setbeamercolor{normal text}{fg=ucltext, bg=uclbg}
\setbeamercolor{background canvas}{bg=uclbg}
\setbeamercolor{structure}{fg=ucldarkpurple}
\setbeamercolor{alerted text}{fg=uclbrightpurple}
\setbeamercolor{example text}{fg=ucldarkgold}

\setbeamercolor{frametitle}{fg=ucldarkpurple, bg=uclbg}
\setbeamercolor{title}{fg=uclbg}
\setbeamercolor{subtitle}{fg=uclbg}
\setbeamercolor{author}{fg=uclbg}
\setbeamercolor{date}{fg=uclbg}
\setbeamercolor{institute}{fg=uclbg}

\setbeamercolor{itemize item}{fg=ucldarkgold}
\setbeamercolor{itemize subitem}{fg=ucldarkgold}
\setbeamercolor{itemize subsubitem}{fg=ucldarkgold}
\setbeamercolor{enumerate item}{fg=ucldarkgold}
\setbeamercolor{enumerate subitem}{fg=ucldarkgold}

\setbeamercolor{block title}{fg=uclbg, bg=ucldarkpurple}
\setbeamercolor{block body}{fg=ucltext, bg=uclbg!92!ucldarkpurple}

%%%============================================================
%%%  Beamer fonts & Templates
%%%============================================================
\setbeamerfont{subtitle}{family=\sffamily, size=\normalsize}
\setbeamerfont{author}{family=\sffamily, series=\bfseries, size=\small}
\setbeamerfont{date}{family=\sffamily, size=\footnotesize}
\setbeamerfont{institute}{family=\sffamily, size=\footnotesize}
\setbeamerfont{footline}{family=\sffamily, size=\scriptsize}

\newlength{\uclbasesize}
\AtBeginDocument{\makeatletter\uclbasesize=\f@size pt\makeatother}

\setbeamerfont{frametitle}{family=\sffamily, series=\bfseries,
  size=\fontsize{\dimexpr1.5\uclbasesize\relax}{\dimexpr1.8\uclbasesize\relax}\selectfont}

\setbeamertemplate{navigation symbols}{}
\useinnertheme{default}

% Itemize template
\setbeamertemplate{itemize item}{\raisebox{0.15ex}{\color{ucldarkgold}\rule{0.55ex}{0.55ex}}}
\setbeamertemplate{itemize subitem}{\raisebox{0.15ex}{\color{ucldarkgold}\rule{0.45ex}{0.45ex}}}
\setbeamertemplate{itemize subsubitem}{\raisebox{0.15ex}{\color{ucldarkgold}\rule{0.35ex}{0.35ex}}}
\setbeamertemplate{enumerate item}{\color{ucldarkgold}\bfseries\insertenumlabel.}

% Blocks template
\setbeamertemplate{block begin}{%
  \setbeamercolor{block title}{fg=uclbg, bg=ucldarkpurple}%
  \begin{beamercolorbox}[colsep*=.75ex, sep=0.4ex, rounded=true]{block title}%
    \usebeamerfont*{block title}\insertblocktitle
  \end{beamercolorbox}%
  \nointerlineskip
  \begin{beamercolorbox}[colsep*=.75ex, sep=0.6ex, vmode, rounded=true]{block body}%
}
\setbeamertemplate{block end}{\end{beamercolorbox}\vspace*{0.5ex}}

% Frametitle template
\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \vspace{0.6ex}
  \begin{beamercolorbox}[wd=\paperwidth, ht=3.2ex, dp=1.2ex, leftskip=0.05\paperwidth]{frametitle}%
    \usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}%
    \insertframetitle%
  \end{beamercolorbox}%
}

% Blockquotes Environment
\newenvironment{uclquote}{%
  \begin{tcolorbox}[colback=uclbg!96!uclnavy, colframe=ucldarkgold,
                    boxrule=0pt, leftrule=1.2pt, arc=0pt, outer arc=0pt,
                    left=6pt, right=6pt, top=4pt, bottom=4pt]%
  \color{uclnavy}\itshape
}{\end{tcolorbox}}

%%%============================================================
%%%  Footline Setup
%%%============================================================
\setbeamertemplate{footline}{%
  \ifnum\insertframenumber=1\relax
    % Title frame background doesn't require a footer band
  \else
    \begin{tikzpicture}[remember picture, overlay]
      \clip (current page.south west) rectangle (current page.north east);
      
      \fill[uclbrightpurple] (current page.south west) 
        rectangle ($(current page.south west) + (0.10\paperwidth, 0.55cm)$);
      \fill[ucldarkpurple] ($(current page.south west) + (0.10\paperwidth, 0cm)$) 
        rectangle ($(current page.south east) + (0cm, 0.55cm)$);
      
      \node[anchor=west, font=\sffamily\scriptsize, text=uclfootertext, text width=0.75\paperwidth, align=left]
        at ($(current page.south west) + (0.11\paperwidth, 0.275cm)$) {
          \textcopyright{} \insertshortauthor{} \textbar{} \puretext{\insertshorttitle} \textbar{} \insertshortconference{} \textbar{} \insertshortdate{}
        };
        
      \node[anchor=east, font=\sffamily\scriptsize, text=uclfootertext]
        at ($(current page.south east) + (-0.02\paperwidth, 0.275cm)$) {\insertframenumber/\inserttotalframenumber};
        
      \ifuclNoLogo\else
        \node[anchor=south east, inner sep=2pt]
          at ($(current page.south east) + (-0.01\paperwidth, 0.55cm)$)
          {\includegraphics[height=0.6cm]{\UCLimgpath ucl-new-logo.png}};
      \fi
    \end{tikzpicture}%
    \vspace*{0.55cm}%
    \global\uclNoLogofalse
  \fi
}

%%%============================================================
%%%  Title page template
%%%============================================================
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \clip (current page.south west) rectangle (current page.north east);
    
    \fill[uclbrightpurple] (current page.north west) rectangle ($(current page.south west) + (0.10\paperwidth, 0cm)$);
    \fill[ucldarkpurple] ($(current page.north west) + (0.10\paperwidth, 0cm)$) rectangle (current page.south east);

    \node[anchor=south east, inner sep=10pt] at (current page.south east)
      {\includegraphics[height=1.0cm]{\UCLimgpath ucl-new-title.png}};

    \node[anchor=north west] at ($(current page.north west) + (0.11\paperwidth, -0.14\paperheight)$)
      {\color{uclbg}\sffamily\bfseries\Huge
       \begin{minipage}[t]{0.82\paperwidth}%
         \setlength{\baselineskip}{1em}%
         \raggedright
         \inserttitle
       \end{minipage}};

    \node[anchor=north west, text=uclbg, font=\sffamily\Large, text width=0.82\paperwidth, align=left]
      at ($(current page.north west) + (0.11\paperwidth, -0.35\paperheight)$)
      {\color{uclbg!70!ucldarkpurple}\insertsubtitle};

    \node[anchor=north west, text=uclbg, font=\sffamily\bfseries\normalsize, text width=0.82\paperwidth, align=left]
      at ($(current page.north west) + (0.11\paperwidth, -0.45\paperheight)$)
      {\insertauthor};

    \node[anchor=north west, text=uclgold, font=\sffamily\scriptsize, text width=0.82\paperwidth, align=left]
      at ($(current page.north west) + (0.11\paperwidth, -0.50\paperheight)$)
      {\insertsocials\par};

    \node[anchor=north west, text=uclbg,
          font=\sffamily\normalsize,
          text width=0.82\paperwidth, align=left]
      at ($(current page.north west) + (0.11\paperwidth, -0.68\paperheight)$)
      {\color{uclbg!75!ucldarkpurple}\insertdate 
       \ifx\insertconference\undefined\else \\ \insertconference\fi};

    % institute at the bottom (empty = nothing rendered)
    \node[anchor=south west, text=uclbg,
          font=\sffamily\small,
          text width=0.82\paperwidth, align=left]
      at ($(current page.south west) + (0.11\paperwidth, 0.05\paperheight)$)
      {\color{uclbg!75!ucldarkpurple}\insertinstitute};
  \end{tikzpicture}%
}

%%%============================================================
%%%  Section divider slides
%%%============================================================
\AtBeginSection[]{%
  \global\uclNoLogofalse
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[remember picture, overlay]
      \clip (current page.south west) rectangle (current page.north east);
      
      \fill[uclbrightpurple] (current page.north west) rectangle ($(current page.south west) + (0.045\paperwidth, 0cm)$);
      \fill[ucldarkpurple] ($(current page.north west) + (0.045\paperwidth, 0cm)$) rectangle ($(current page.south west) + (0.145\paperwidth, 0cm)$);
      \fill[uclbrightpurple] ($(current page.north west) + (0.145\paperwidth, 0cm)$) rectangle ($(current page.south west) + (0.255\paperwidth, 0cm)$);
      \fill[ucldarkpurple] ($(current page.north west) + (0.255\paperwidth, 0cm)$) rectangle (current page.south east);

      \node[anchor=south east, inner sep=10pt] at (current page.south east)
        {\includegraphics[height=1.2cm]{\UCLimgpath ucl-new-title.png}};

      \node[anchor=west, text=uclbg, font=\sffamily\bfseries\Huge, text width=0.65\paperwidth, align=left]
        at ($(current page.west) + (0.30\paperwidth, 0cm)$) {\insertsectionhead};
    \end{tikzpicture}
  \end{frame}
}

%%%============================================================
%%%  Custom divider frame setup
%%%============================================================
\newcommand{\uclDividerFrameStart}[1]{%
  \setbeamertemplate{frametitle}{}%
  \vspace*{0.18\paperheight}%
  \hspace*{0.08\paperwidth}\begin{minipage}[t]{0.80\paperwidth}%
    \sffamily
    {\color{ucldarkpurple}\bfseries\Huge #1\par}
    \vspace{1em}
    \color{ucltext}\normalsize
}
\newcommand{\uclDividerFrameEnd}{\end{minipage}}

