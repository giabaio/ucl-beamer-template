% ============================================================
% Engine-Dependent Font Handling (Clean Reference Mechanism)
% ============================================================
\ifpdftex
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
  \IfFileExists{aptos.sty}{%
    \RequirePackage{aptos}%
  }{%
    \IfFileExists{FiraSans.sty}{%
      \RequirePackage{FiraSans}%
    }{%
      \IfFileExists{carlito.sty}{%
        \RequirePackage{carlito}%
      }{%
        \RequirePackage{helvet}%
      }%
    }%
  }
  \renewcommand{\familydefault}{\sfdefault}
  \RequirePackage{bm}
  \usefonttheme[onlymath]{serif}
\else
  \RequirePackage{fontspec}
  % Force Computer Modern serif/sans for maths under XeLaTeX/LuaLaTeX
  \usefonttheme[onlymath]{serif}
  
  % Load UCL Sans safely if present, otherwise default to system sans
  \IfFileExists{css/fonts/UCLSans-Regular.ttf}{%
    \setsansfont{UCLSans}[
      Path           = css/fonts/,
      Extension      = .ttf,
      UprightFont    = *-Regular,
      BoldFont       = *-Bold
    ]%
  }{%
    \IfFontExistsTF{UCL Sans}{%
      \setsansfont{UCL Sans}%
    }{}%
  }
\fi

